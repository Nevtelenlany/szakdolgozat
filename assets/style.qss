/*címsor*/
QLabel#MainTitle {
    font-size: 24px; 
    font-weight: bold; 
    margin-bottom: 20px;
    color: #49668C;
}

/*még nincs témakör szövege*/
QLabel#EmptyText, QLabel#EmptyText2 {
    font-size: 16px;
    font-style: italic;
    padding-top: 10px;
    padding-bottom: 10px;
    color: #666666;
    qproperty-alignment: AlignCenter;
}

/*temakor hozza adas*/
QPushButton#ActionButton {
    background-color: transparent;
    font-size: 16px;
    font-weight: bold;
    color: #7092BE;
    border: none;
    outline: none;
    qproperty-iconSize: 24px 24px;
    qproperty-icon: url(assets/icons/hozzadas_gomb.png);
}

/*kilepes*/
QPushButton#ActionButton2 {
    background-color: transparent;
    font-size: 16px;
    font-weight: bold;
    color: #7092BE;
    border: none;
    outline: none;
}

/* Hover effekt */
QPushButton#ActionButton:hover, QPushButton#ActionButton2:hover {
    color: #0078D7;
}

/* Kattintás effekt*/
QPushButton#ActionButton:pressed, QPushButton#ActionButton2:pressed {
    color: #005a9e; 
}

/*temakorok gombja*/
QPushButton#SubjectButton {
    background-color: #ffffff;
    border: 2px solid #e0e0e0;
    border-radius: 10px; 
    font-size: 18px;
    font-weight: bold;
    color: #49668C;
}

QPushButton#SubjectButton:hover {
    border: 2px solid #0078D7;
    background-color: #f0f8ff; 
}

QPushButton#SubjectButton:checked {
    background-color: #d0e8ff;
    border: 2px solid #005a9e;
}

/*görgő*/
QScrollArea {
    border: none;
}

QWidget#LeftMenuWidget {
    background-color: #9fb1c9; 
    border-right: 1px solid #e4e4e4; 
}

QPushButton#MenuButton {
    background-color: transparent;
    font-size: 20px; 
    font-weight: bold;
    color: #ffffff; 
    text-align: left;
    padding: 15px 10px 15px 20px;
    border: none; 
}

QPushButton#MenuButton:hover {
    color: #49668C; 
}

/* Táblázat alapstílusa*/
QTableWidget {
    background-color: transparent; 
    color: white;
    border: none;
    qproperty-alternatingRowColors: true; 

    font-weight: bold; 
    font-size: 16px;
    font-style: italic;
    padding-top: 10px;
    padding-bottom: 10px;
}

/* Táblázat fejléce */
QHeaderView::section {
    background-color: transparent;
    color: #49668C; 
    border: none;
    border-bottom: 2px solid #555555;
    font-weight: bold;
    padding-left: 5px; 
}

/* Táblázat cellái*/
QTableWidget::item {
    background-color: #7092BE; 
    border: none;
    padding-left: 5px; 
}

/* Táblázat cellái*/
QTableWidget::item:alternate {
    background-color: #9fb1c9; 
}

QTableWidget QWidget {
    background-color: transparent;
    color: #e0e0e0; 
}

/*cahtbot*/

QWidget#MessagesWidget {
    background-color: #f5f5f5;
}

/* Üzenet beviteli mező */
QLineEdit#MessageInput {
    padding: 10px; 
    border-radius: 15px; 
    border: 1px solid #ccc;
    font-size: 14px;
}

/* Küldés gomb */
QPushButton#SendButton {
    padding: 10px 20px; 
    background-color: #7092BE; 
    color: white; 
    border-radius: 15px; 
    font-weight: bold;
    font-size: 14px;
}

QPushButton#SendButton:disabled {
    background-color: #a0c4e8;
    color: #f0f0f0;
}

/* "Gondolkodik..." szöveg */
QLabel#ThinkingLabel {
    color: gray; 
    font-style: italic;
    font-size: 14px;
}

/* Felhasználó chat buborékja*/
QLabel#UserBubble {
    background-color: #9fb1c9; 
    padding: 12px; 
    border-radius: 12px; 
    font-size: 14px;

    color: white;
    font-weight: bold; 
    font-size: 16px;
    font-style: italic;
    padding-top: 10px;
    padding-bottom: 10px;
}

/* Bot chat buborékja*/
QLabel#BotBubble {
    background-color: #ffffff; 
    padding: 12px; 
    border-radius: 12px; 
    border: 1px solid #cccccc;

    color: gray;
    font-weight: bold; 
    font-size: 16px;
    font-style: italic;
    padding-top: 10px;
    padding-bottom: 10px;
}